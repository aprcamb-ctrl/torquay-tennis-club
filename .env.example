# ============================================
# CHAT WIDGET - Required for AI assistant
# ============================================
# 1. Get a free API key: https://aistudio.google.com/apikey
# 2. Copy this file: cp .env.example .env
# 3. Replace YOUR_KEY_HERE below with your actual key
# 4. Restart the dev server (npm run dev)
#
VITE_GEMINI_API_KEY=YOUR_KEY_HERE
# (Alternatively you can use GEMINI_API_KEY instead)

# APP_URL: Used when hosted (e.g. Cloud Run)
APP_URL="MY_APP_URL"
