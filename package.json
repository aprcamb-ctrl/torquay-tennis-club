{
  "name": "torquay-tennis-club",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tinacms dev -c 'vite --port=3000 --host=0.0.0.0'",
    "build": "tinacms build && vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "server": "tsx server.ts",
    "subscribers": "echo '--- NEWSLETTER ---' && sqlite3 subscribers.db 'SELECT * FROM subscribers;' && echo '\n--- CLUBHOUSE BOOKINGS ---' && sqlite3 subscribers.db 'SELECT * FROM clubhouse_bookings;'"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vercel/analytics": "^2.0.1",
    "@vitejs/plugin-react": "^5.0.4",
    "better-sqlite3": "^12.4.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "resend": "^4.1.2",
    "tinacms": "^3.6.3",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@tinacms/cli": "^2.1.11",
    "@types/express": "^4.17.21",
    "@types/node": "^22.19.15",
    "@vercel/node": "^3.0.0",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
